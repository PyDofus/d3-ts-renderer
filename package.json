{
  "name": "d3-ts-renderer",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "generate-fbs": "flatc --ts -o src/data/fbs/generated fbs/skin.fbs fbs/bone.fbs fbs/common.fbs",
    "prepare": "npm run build",
    "dev": "vite -c example/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "liveExtract": "uv run fastapi run"
  },
  "devDependencies": {
    "@types/gl": "^6.0.5",
    "@types/node": "^25.6.0",
    "@types/sharp": "^0.31.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "mediabunny": "^1.41.0"
  },
  "peerDependencies": {
    "gl": "^8.1.6",
    "sharp": "^0.34.5"
  },
  "peerDependenciesMeta": {
    "gl": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  }
}
